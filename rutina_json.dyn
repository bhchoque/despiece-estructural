    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitServices')\r\nclr.AddReference('RevitAPI')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom Autodesk.Revit.DB import FilteredElementCollector, BuiltInCategory, LocationCurve\r\nimport math, json, os\r\nfrom datetime import date\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndef get_param(elem, nombre):\r\n    try:\r\n        p = elem.LookupParameter(nombre)\r\n        if p is None: return \"\"\r\n        return p.AsString() or str(p.AsValueString()) or \"\"\r\n    except: return \"\"\r\n\r\ndef pt(p):\r\n    return {\"x\": round(float(p.X)*0.3048,4), \"y\": round(float(p.Y)*0.3048,4), \"z\": round(float(p.Z)*0.3048,4)}\r\n\r\ndef lon3d(p1, p2):\r\n    return round(math.sqrt((p2[\"x\"]-p1[\"x\"])**2+(p2[\"y\"]-p1[\"y\"])**2+(p2[\"z\"]-p1[\"z\"])**2),4)\r\n\r\nvigas_raw = list(FilteredElementCollector(doc).OfCategory(BuiltInCategory.OST_StructuralFraming).WhereElementIsNotElementType().ToElements())\r\n\r\nelementos = []\r\nfor v in vigas_raw:\r\n    try:\r\n        loc = v.Location\r\n        if not isinstance(loc, LocationCurve): continue\r\n        c = loc.Curve\r\n        inicio  = pt(c.GetEndPoint(0))\r\n        fin     = pt(c.GetEndPoint(1))\r\n        elementos.append({\r\n            \"id\":       int(v.Id.IntegerValue),\r\n            \"marca\":    str(get_param(v,\"Mark\") or \"VG-\"+str(v.Id.IntegerValue)),\r\n            \"nivel\":    str(get_param(v,\"Nivel de referencia\")),\r\n            \"seccion\":  str(v.Name),\r\n            \"inicio\":   inicio,\r\n            \"fin\":      fin,\r\n            \"longitud\": lon3d(inicio, fin)\r\n        })\r\n    except: continue\r\n\r\nruta = \"D:/Documents/01_Programas/Programa_despieces/vigas.json\"\r\n\r\npayload = {\r\n    \"proyecto\": \"PROYECTO_INICIAL\",\r\n    \"fecha\":    str(date.today()),\r\n    \"unidades\": \"metros\",\r\n    \"elementos\": elementos\r\n}\r\n\r\nos.makedirs(os.path.dirname(ruta), exist_ok=True)\r\nwith open(ruta, \"w\", encoding=\"utf-8\") as f:\r\n    json.dump(payload, f, indent=2, ensure_ascii=False)\r\n\r\nOUT = \"Exportado: \" + ruta + \" — \" + str(len(elementos)) + \" elementos\"",
