    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitServices')\r\nclr.AddReference('RevitAPI')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom Autodesk.Revit.DB import FilteredElementCollector, BuiltInCategory, LocationCurve\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndef get_param(elem, nombre):\r\n    try:\r\n        p = elem.LookupParameter(nombre)\r\n        if p is None: return \"\"\r\n        return p.AsString() or str(p.AsValueString()) or \"\"\r\n    except: return \"\"\r\n\r\ndef pt(p):\r\n    return {\"x\": round(p.X*0.3048,4), \"y\": round(p.Y*0.3048,4), \"z\": round(p.Z*0.3048,4)}\r\n\r\nvigas_raw = list(FilteredElementCollector(doc).OfCategory(BuiltInCategory.OST_StructuralFraming).WhereElementIsNotElementType().ToElements())\r\ncols_raw = list(FilteredElementCollector(doc).OfCategory(BuiltInCategory.OST_StructuralColumns).WhereElementIsNotElementType().ToElements())\r\n\r\nvigas = []\r\nfor v in vigas_raw:\r\n    try:\r\n        loc = v.Location\r\n        if not isinstance(loc, LocationCurve): continue\r\n        c = loc.Curve\r\n        vigas.append({\r\n            \"id\":      v.Id.IntegerValue,\r\n            \"marca\":   get_param(v,\"Mark\") or \"VG-\"+str(v.Id.IntegerValue),\r\n            \"nivel\":   get_param(v,\"Nivel de referencia\"),\r\n            \"seccion\": v.Name,\r\n            \"inicio\":  pt(c.GetEndPoint(0)),\r\n            \"fin\":     pt(c.GetEndPoint(1))\r\n        })\r\n    except: continue\r\n\r\ncols = []\r\nfor c in cols_raw:\r\n    try:\r\n        loc = c.Location\r\n        if not isinstance(loc, LocationCurve): continue\r\n        cv = loc.Curve\r\n        cols.append({\r\n            \"id\":   c.Id.IntegerValue,\r\n            \"base\": pt(cv.GetEndPoint(0)),\r\n            \"tope\": pt(cv.GetEndPoint(1))\r\n        })\r\n    except: continue\r\n\r\nOUT = [vigas, cols, \"Vigas: \"+str(len(vigas))+\" | Columnas: \"+str(len(cols))]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "678b6da2204b474ca15ac576f9aac990",
